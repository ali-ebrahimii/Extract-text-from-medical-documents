DATABASE_URL=sqlite:///./medical_documents.db
STORAGE_DIR=storage
MAX_UPLOAD_MB=20

# PDF text-layer threshold (chars) above which a PDF is treated as a text PDF.
PDF_TEXT_THRESHOLD=40
# Max pages rendered/preprocessed for scanned PDFs.
MAX_PREPROCESS_PAGES=5

# OCR configuration
# OCR_BACKEND: tesseract | paddleocr | auto
OCR_BACKEND=tesseract
ENABLE_PADDLEOCR=false
# Tesseract language data (eng+fas for English + Persian reports)
TESSERACT_LANG=eng+fas
# PaddleOCR language
PADDLEOCR_LANG=en

# Privacy / behavior
ALLOW_RAW_NATIONAL_ID=false
BLOCK_DUPLICATE_UPLOADS=false
