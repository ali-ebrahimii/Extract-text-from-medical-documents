MAX_UPLOAD_MB=20

# PDF text-layer threshold (chars) above which a PDF is treated as a text PDF.
PDF_TEXT_THRESHOLD=40
# Max pages rendered/preprocessed for scanned PDFs.
MAX_PREPROCESS_PAGES=5

# OCR configuration
# OCR_BACKEND: tesseract | paddleocr | auto
OCR_BACKEND=tesseract
ENABLE_PADDLEOCR=false
# Tesseract language data (eng+fas for English + Persian reports)
TESSERACT_LANG=eng+fas
# PaddleOCR language
PADDLEOCR_LANG=en

# Privacy / behavior
ALLOW_RAW_NATIONAL_ID=false

# Optional debug behavior for local development only.
DEBUG_OUTPUT_DIR=debug_output
DEBUG_SAVE_INTERMEDIATE_FILES=false

# URL-based backend integration (pre-signed temporary file URLs)
FILE_URL_ALLOWED_HOSTS=
FILE_URL_ALLOW_PRIVATE_HOSTS=false
FILE_URL_TIMEOUT_SECONDS=15
FILE_URL_MAX_REDIRECTS=3

# Backend user-files orchestration
BACKEND_FILE_LIST_URL_TEMPLATE=
BACKEND_FILE_FETCH_URL_TEMPLATE=
BACKEND_API_TOKEN=
BACKEND_API_TIMEOUT_SECONDS=15
BACKEND_API_MAX_FILES=50
BACKEND_API_FILE_RESPONSE_MODE=auto
